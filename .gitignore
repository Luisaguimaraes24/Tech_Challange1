# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Ambientes virtuais ─────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Dados ─────────────────────────────────────────────────────────────────
data/raw/
data/processed/
*.csv
*.parquet
*.json
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep

# ── Modelos e artefatos ────────────────────────────────────────────────────
models/
*.pkl
*.joblib
*.pt
*.pth
!models/.gitkeep

# ── MLflow ────────────────────────────────────────────────────────────────
mlruns/
mlartifacts/

# ── Outputs / gráficos ────────────────────────────────────────────────────
outputs/
!outputs/.gitkeep

# ── Jupyter ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDEs e editores ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── Testes e cobertura ────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Ruff cache ────────────────────────────────────────────────────────────
.ruff_cache/